[
{% for post in site.posts %}
{
  "title": {{ post.title | jsonify }},
  "url": {{ post.url | jsonify }},
  "description": {{ post.description | jsonify }},
  "tags": {{ post.tags | jsonify }},
  "icon": {{ post.icon | jsonify }}
}{% unless forloop.last %},{% endunless %}
{% endfor %}
]
